# Python bytecode cache
__pycache__/
*.py[cod]
*$py.class

# Virtual environments
.venv/
venv/
env/

# Local runtime data (optional, keep if you want persistence in repo)
# data/

# 运行态敏感/临时文件（禁止入库）
